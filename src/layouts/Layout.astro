---
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import "../styles/global.css";

const {
    title = "OrionSoft | Soluciones Tecnologicas Innovadoras",
    description = "OrionSoft es una empresa especializada en desarrollo de software, soluciones web y tecnología innovadora para impulsar negocios en la era digital.",
    image = "/favicon.svg",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
	    <!-- Meta Basic -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#0f172a" />
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={Astro.url} />
		
		<!-- Favicon -->
		<link rel="icon" type="image/png" sizes="64x64" href={`${import.meta.env.BASE_URL}/Logo.png`} />
		
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:locale" content="es_DO" />
		<meta property="og:site_name" content="OrionSoft" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		
		<!-- Robots -->
		<meta name="robots" content="index, follow" />
		
		<!-- Preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	
	<body class="min-h-screen antialiased">
		<Navbar />
		
	    <main>
    		<slot />
		</main>
		
		<Footer />
	</body>
</html>
