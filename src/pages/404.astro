---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Página no encontrada">
  <section class="relative min-h-svh flex items-center justify-center px-6 text-center overflow-hidden">
    <!-- Background glow -->
    <div class="absolute w-150 h-75 bg-[radial-gradient(circle,rgba(99,102,241,0.18),transparent_70%)] blur-3xl top-1/4 left-1/2 -translate-x-1/2" />

    <!-- Floting noise / depth -->
    <div class="absolute inset-0 opacity-5 bg-[radial-gradient(circle,#fff_1px,transparent_1px)] bg-size-[20px_20px]" />

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center gap-5 max-w-md">
      <!-- 404 -->
      <h1 class="text-[clamp(6rem,12vw,10rem)] font-black tracking-tighter text-md-outline select-none leading-none">
        404
      </h1>

      <!-- Title -->
        <h2 class="text-2xl md:text-3xl font-bold text-md-primary">
        Página no encontrada
      </h2>

      <!-- Description -->
      <p class="text-md-on-surface-muted text-sm md:text-base leading-relaxed">
        Esta ruta no existe o fue movida a otro lugar.
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 mt-4">
        <a
          href="/orionsoft"
          class="px-6 py-3 rounded-full text-sm font-medium bg-md-primary text-md-on-primary hover:scale-103 transition-all duration-200"
        >
          Volver al inicio
        </a>

        <a
          href="/orionsoft#contact"
          class="px-6 py-3 rounded-full text-sm font-medium border border-md-outline transition"
        >
          Contacto
        </a>
      </div>
    </div>
  </section>
</Layout>