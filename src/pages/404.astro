---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Página no encontrada">
  <main class="min-h-screen bg-gray-950 flex items-center justify-center px-6">
    <div class="text-center max-w-lg mx-auto">

      <!-- Número 404 -->
      <p class="text-[10rem] font-black text-gray-900 leading-none select-none tracking-tighter">
        404
      </p>

      <!-- Línea decorativa -->
      <div class="w-12 h-0.5 bg-emerald-500 mx-auto -mt-4 mb-8"></div>

      <!-- Texto -->
      <h1 class="text-2xl font-bold text-white mb-3 tracking-tight">
        Página no encontrada
      </h1>
      <p class="text-gray-400 leading-relaxed mb-10">
        La página que buscas no existe o fue movida. Vuelve al inicio y sigue explorando.
      </p>

      <!-- Botones -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-emerald-500 text-white text-sm font-semibold rounded-xl hover:bg-emerald-400 transition-colors duration-200"
        >
          Volver al inicio
        </a>
        <a
          href="#contact"
          class="px-6 py-3 bg-transparent border-2 border-gray-700 text-gray-300 text-sm font-semibold rounded-xl hover:border-emerald-800 hover:text-emerald-400 transition-colors duration-200"
        >
          Contáctanos
        </a>
      </div>

    </div>
  </main>
</Layout>