---
import ProjectsFilter from "../components/sections/projects/ProjectsFilter.astro";
import ProjectsGrid from "../components/sections/projects/ProjectsGrid.astro";
import { getCollection } from 'astro:content'
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/projects/Hero.astro";

const projects = await getCollection('projects');

const categories = ['Todos', ...new Set(projects.map(p => p.data.category))]
---

<Layout>

    <Hero />
    <ProjectsFilter categories={categories} />
    <ProjectsGrid projects={projects} />

</Layout>    