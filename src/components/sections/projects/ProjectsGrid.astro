---
// src/components/sections/Services.astro

const services = [
  {
    title: "Desarrollo Web",
    description: "Creamos aplicaciones modernas y rápidas utilizando las últimas tecnologías como Astro, React y Svelte.",
    icon: "🌐",
  },
  {
    title: "Diseño UI/UX",
    description: "Interfaces intuitivas y atractivas centradas en la experiencia del usuario y la identidad de tu marca.",
    icon: "🎨",
  },
  {
    title: "Optimización SEO",
    description: "Mejoramos el posicionamiento de tu sitio en buscadores para aumentar tu visibilidad orgánica.",
    icon: "🚀",
  },
  {
    title: "Consultoría IT",
    description: "Te asesoramos en la elección de la infraestructura tecnológica adecuada para escalar tu negocio.",
    icon: "💡",
  },
];
---

<section class="py-20 px-6 bg-transparent">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Nuestros Servicios
    </h2>
    <p class="text-gray-400 mb-12 max-w-2xl mx-auto">
      Soluciones tecnológicas personalizadas para impulsar tu presencia digital y optimizar tus procesos.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="p-8 rounded-2xl bg-zinc-900/50 border border-zinc-800 hover:border-orange-500/50 transition-all duration-300 group">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">
            {service.icon}
          </div>
          <h3 class="text-xl font-semibold text-white mb-2">
            {service.title}
          </h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>