---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

type Project = CollectionEntry<'projects'>

const projects: Project[] = await getCollection('projects')

const sorted = projects.sort((a, b) => Number(b.data.year) - Number(a.data.year))
---

<section class="px-6 pb-32" id="proyectos">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
            <div>
                <span class="label-small text-md-surface-muted">
                    Trabajo Selecto
                </span>

                <h2 class="headline-large mt-2 text-md-primary">
                    Proyectos Destacados
                </h2>
            </div>

            <a 
                href="/orionsoft/projects" 
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-full border border-md-outline text-md-primary hover:bg-md-surface-variant transition"
            > 
                Ver todos
                <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M9 4l4 4-4 4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"/>
                </svg>
            </a>
        </div>

        <!-- List -->
        <div class="flex flex-col border border-md-outline-variant rounded-2xl overflow-hidden">
            {projects.map((p, i) => (
                <a 
                    href={`/orionsoft/projects/${p.id}`}
                    class="grid grid-cols-[48px_1fr_40px] md:grid-cols-[56px_1fr_48px] gap-4 md:gap-6 px-6 md:px-9 py-8 md:py-10 bg-md-surface border-b border-md-outline-variant hover:bg-md-outline-variant transition group"
                >
                    {/* Number */}
                    <span class="text-xs font-mono text-md-surface-muted pt-1">
                        {(i + 1).toString().padStart(2, '0')}
                    </span>

                    {/* Content */}
                    <div class="flex flex-col gap-2.5">
                        <div class="flex items-center gap-4">
                            <span class="text-xs uppercase tracking-[0.08em] text-md-on-surface-muted">
                                {p.data.category}
                            </span>

                            <span class="ml-auto text-xs text-md-on-surface-muted">
                                {p.data.year}
                            </span>
                        </div>

                        <h3 class="text-lg md:text-xl font-semibold text-ink-200 group-hover:text-md-primary transition">
                            {p.data.title}
                        </h3>

                        <p class="text-sm leading-relaxed max-w-140 text-md-on-surface-muted">
                            {p.data.desc}
                        </p>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-2 pt-1">
                            {p.data.tags.map(tag => (
                                <span class="text-xs px-3 py-1 rounded-full border border-md-outline-variant bg-md-surface-container text-md-on-surface-muted">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>

                    <!-- Arrow -->
                    <div class="flex items-start justify-center pt-1 text-md-on-surface-muted group-hover:text-md-primary transition">
                        <svg class="w-5 h-5 transform transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
                            viewBox="0 0 20 20" fill="none">
                            <path d="M4 16L16 4M16 4H8M16 4v8"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"/>
                        </svg>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>