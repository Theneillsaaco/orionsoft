---
const projects = [
  {
    slug: 'fintrack',
    label: 'Finanzas personales',
    title: 'FinTrack',
    desc: 'App móvil de gestión financiera con análisis inteligente de gastos.',
    tags: ['Flutter', 'Firebase', 'Figma'],
    year: '2024',
    num: '01',
  },
  {
    slug: 'logiq',
    label: 'Plataforma SaaS',
    title: 'Logiq Dashboard',
    desc: 'Panel logístico con rutas, inventario y analytics.',
    tags: ['Next.js', 'PostgreSQL', 'AWS'],
    year: '2024',
    num: '02',
  },
  {
    slug: 'studio-site',
    label: 'Sitio corporativo',
    title: 'Estudio Creativo',
    desc: 'Web para estudio con animaciones y CMS.',
    tags: ['Astro', 'Svelte', 'Sanity'],
    year: '2023',
    num: '03',
  },
];
---

<section class="px-6 pb-32" id="proyectos">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between">
            <div>
                <span class="label-small text-(--color-md-surface-muted)">
                    Trabajo Selecto
                </span>

                <h2 class="headline-large mt-2 text-md-primary">
                    Proyectos Destacados
                </h2>
            </div>

            <a 
                href="/orionsoft/projects" 
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-full border border-(--color-md-outline) text-[var(--color-md-primary) hover:bg-(--color-md-surface-variant) transition"
            > 
                Ver todos
                <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8h10M9 4l4 4-4 4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"/>
                </svg>
            </a>
        </div>

        <!-- List -->
        <div class="flex flex-col border border-(--color-md-outline-variant) rounded-2xl overflow-hidden">
            {projects.map(p => (
                <a 
                    href={`/orionsoft/projects/${p.slug}`}
                    class="grid grid-cols-[48px_1fr_40px] md:grid-cols-[56px_1fr_48px] gap-4 md:gap-6 px-6 md:px-9 py-8 md:py-10 bg-(--color-md-surface) border-b border-(--color-md-outline-variant) hover:bg-[var(--color-md-outline-variant)] transition hover:bg-[var(--color-md-surface-variant)] group"
                >
                    {/* Number */}
                    <span class="text-xs font-mono text-(--color-md-surface-muted) pt-1">
                        {p.num}
                    </span>

                    {/* Content */}
                    <div class="flex flex-col gap-2.5">
                        <div class="flex items-center gap-4">
                            <span class="text-xs uppercase tracking-[0.08em] text-(--color-md-on-surface-muted)">
                                {p.label}
                            </span>

                            <span class="ml-auto text-xs text-md-on-surface-muted">
                                {p.year}
                            </span>
                        </div>

                        <h3 class="text-lg md:text-xl font-semibold
                                text-ink-200
                                group-hover:text-md-primary
                                transition"
                        >

                            {p.title}
                        </h3>

                        <p class="text-sm leading-relaxed max-w-140 text-md-on-surface-muted">
                            {p.desc}
                        </p>

                        <!-- Tags -->
                        <div class="flex flex-wrap gap-2 pt-1">
                            {p.tags.map(tag => (
                                <span class="text-xs px-3 py-1 rounded-full
                                            border border-md-outline-variant
                                            bg-md-surface-container
                                            text-md-on-surface-muted"
                                >
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>

                    <!-- Arrow -->
                    <div class="flex items-start justify-center pt-1 text-md-on-surface-muted group-hover:text-md-primary transition">
                        <svg class="w-5 h-5 transform transition-transform
                                    group-hover:translate-x-1 group-hover:-translate-y-1"
                            viewBox="0 0 20 20" fill="none">

                        <path d="M4 16L16 4M16 4H8M16 4v8"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"/>
                        </svg>

                    </div>
                </a>
            ))}

        </div>
    </div>
</section>