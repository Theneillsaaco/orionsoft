---
const services = [
  {
    icon: `<path d="M3 12l2-2m0 0l7-7 7 7..." />`,
    title: 'Desarrollo Web',
    desc: 'Sitios y plataformas modernas y escalables.',
    price: 299,
    tags: ['Next.js', 'Astro', 'Laravel'],
    features: ['Responsive', 'SEO básico', 'Alta performance'],
    popular: false,
  },
  {
    icon: `<rect x="5" y="2" width="14" height="20" rx="2" />`,
    title: 'Apps Móviles',
    desc: 'Apps fluidas para iOS y Android.',
    price: 799,
    tags: ['Flutter', 'Swift'],
    features: ['Cross-platform', 'UI moderna', 'Optimización'],
    popular: true,
  },
  {
    icon: `<path d="M7 21a4 4 0 01-4-4..." />`,
    title: 'UI/UX Design',
    desc: 'Diseño centrado en experiencia real.',
    price: 199,
    tags: ['Figma', 'MD3'],
    features: ['Design System', 'Prototipos', 'UX research'],
    popular: false,
  },
];
---

<section class="py-28 px-6" id="servicios">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="max-w-xl mb-16">
      <span class="label-small text-[var(--color-md-on-surface-muted)]">
        Lo que hacemos
      </span>

      <h2 class="headline-large mt-2 text-[var(--color-md-primary)]">
        Servicios
      </h2>

      <p class="body-large mt-2">
        Cubrimos todo el ciclo de vida de tu producto digital.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-[1px] border border-[var(--color-md-outline-variant)] rounded-2xl overflow-hidden bg-[var(--color-md-outline-variant)]">

      {services.map((s) => (
        <div class="relative p-10 bg-[var(--color-md-surface)]
                    flex flex-col gap-5
                    hover:bg-[var(--color-md-surface-variant)]
                    transition">

          {s.popular && (
            <span class="absolute top-4 right-4 text-xs px-3 py-1 rounded-full
                         bg-[var(--color-md-primary)]
                         text-[var(--color-md-on-primary)]">
              Popular
            </span>
          )}

          <!-- Icon -->
          <div class="w-11 h-11 flex items-center justify-center rounded-lg
                      border border-[var(--color-md-outline-variant)]
                      bg-[var(--color-md-surface-variant)]
                      text-[var(--color-md-on-surface-muted)]">

            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
              <Fragment set:html={s.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-semibold text-[var(--color-md-primary)]">
            {s.title}
          </h3>

          <p class="text-sm text-[var(--color-md-on-surface-muted)] leading-relaxed">
            {s.desc}
          </p>

          <!-- Price -->
          <div class="flex items-baseline gap-2 pt-2">
            <span class="text-xs text-[var(--color-md-on-surface-muted)]">
              desde
            </span>
            <span class="text-3xl font-bold text-[var(--color-md-primary)]">
              ${s.price}
            </span>
          </div>

          <!-- Features -->
          <ul class="flex flex-col gap-2 mt-2">
            {s.features.map(f => (
              <li class="text-sm flex items-center gap-2 text-[var(--color-md-on-surface-muted)]">
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-md-primary)]"></span>
                {f}
              </li>
            ))}
          </ul>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 pt-3">
            {s.tags.map(tag => (
              <span class="text-xs px-3 py-1 rounded-full
                           border border-[var(--color-md-outline-variant)]
                           bg-[var(--color-md-surface-container)]
                           text-[var(--color-md-on-surface-muted)]">
                {tag}
              </span>
            ))}
          </div>

          <!-- CTA -->
          <a href="#contact"
             class="mt-4 inline-flex justify-center items-center
                    px-5 py-2.5 rounded-full text-sm font-medium
                    border border-[var(--color-md-outline)]
                    text-[var(--color-md-primary)]
                    hover:bg-[var(--color-md-surface-variant)]
                    transition">

            Solicitar
          </a>

        </div>
      ))}

    </div>
  </div>
</section>