---
const services = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />`,
    title: 'Desarrollo Web',
    desc: 'Sitios y plataformas modernas, rápidas y escalables.',
    price: 299,
    tags: ['Next.js', 'Astro', 'Laravel'],
    features: ['Responsive', 'SEO básico', 'Alta performance'],
    popular: false,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3" />`,
    title: 'Apps Móviles',
    desc: 'Apps fluidas y nativas para iOS y Android.',
    price: 799,
    tags: ['Flutter', 'Swift', 'Kotlin'],
    features: ['Cross-platform', 'UI moderna', 'Optimización'],
    popular: true,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />`,
    title: 'UI/UX Design',
    desc: 'Diseño centrado en la experiencia real del usuario.',
    price: 199,
    tags: ['Figma', 'MD3', 'Prototipos'],
    features: ['Design System', 'Prototipos interactivos', 'UX research'],
    popular: false,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z" />`,
    title: 'Automatización',
    desc: 'Flujos automáticos para que tu negocio trabaje solo.',
    price: 399,
    tags: ['n8n', 'Zapier', 'APIs'],
    features: ['Integraciones', 'Webhooks', 'Reportes automáticos'],
    popular: false,
  },
  {
