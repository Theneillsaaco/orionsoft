---
const contact = {
  email: "orionsoft@gmail.com",
  phone: "+1 (829) 793-1539",
  address: "La Altagracia, Punta Cana, República Dominicana",
  socials: [
    { name: "Instagram", handle: "@orionsoft", url: "https://instagram.com/orionsoft" },
    { name: "LinkedIn", handle: "OrionSoft", url: "https://linkedin.com/company/orionsoft" },
    { name: "GitHub", handle: "Orionsoft", url: "https://github.com/Theneillsaaco" },
    { name: "WhatsApp", handle: "+1 (829) 793-1539", url: "https://wa.me/18297931539" },
  ],
};
---
<section class="px-6 pb-24">
  <div class="max-w-6xl mx-auto">
    <div class="relative overflow-hidden rounded-2xl border border-md-outline-variant bg-md-surface px-8 py-20 text-center">

      <!-- Glow -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-150 h-75 bg-[radial-gradient(circle,rgba(255,255,255,0.05)_0%,transparent_70%)]"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 flex flex-col items-center gap-6">

        <span class="label-small text-md-on-surface-muted">
          ¿Tienes un proyecto?
        </span>

        <h2 class="text-4xl md:text-5xl font-bold leading-tight text-md-primary">
          Hagámoslo realidad
        </h2>

        <p class="text-md-on-surface-muted max-w-md leading-relaxed">
          Cuéntanos tu idea. Respondemos en menos de 24 horas con una propuesta inicial clara.
        </p>

        <div class="flex flex-wrap justify-center gap-3 mt-2">

          <a
            href={`mailto:${contact.email}`}
            class="px-6 py-3 rounded-full text-sm font-medium bg-md-primary text-md-on-primary hover:opacity-90 transition"
          >
            Enviar mensaje
          </a>

          <a
            href="#contact"
            class="px-6 py-3 rounded-full text-sm font-medium border border-md-outline text-md-primary hover:bg-md-surface-variant transition"
          >
            Ver contacto
          </a>

        </div>
      </div>
    </div>
  </div>
</section>

<section id="contact" class="px-6 pb-32">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="label-small text-md-on-surface-muted">
        Contacto
      </span>

      <h2 class="text-3xl md:text-4xl font-bold text-md-primary mt-2">
        Hablemos de tu proyecto
      </h2>

      <p class="text-md-on-surface-muted max-w-md mx-auto mt-3">
        Estamos disponibles para ayudarte a construir algo increíble.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-5">

      <!-- Email -->
      <a
        href={`mailto:${contact.email}`}
        class="group bg-md-surface border border-md-outline-variant rounded-xl p-6 flex flex-col gap-3 hover:bg-md-surface-variant transition"
      >
        <span class="label-small text-md-on-surface-muted">Email</span>
        <span class="text-md-primary font-medium group-hover:underline">
          {contact.email}
        </span>
      </a>

      <!-- Tel -->
      <a
        href={`tel:${contact.phone}`}
        class="group bg-md-surface border border-md-outline-variant rounded-xl p-6 flex flex-col gap-3 hover:bg-md-surface-variant transition"
      >
        <span class="label-small text-md-on-surface-muted">Teléfono</span>
        <span class="text-md-primary font-medium group-hover:underline">
          {contact.phone}
        </span>
      </a>

      <!-- Ubicación -->
      <div class="bg-md-surface border border-md-outline-variant rounded-xl p-6 flex flex-col gap-3">
        <span class="label-small text-md-on-surface-muted">Ubicación</span>
        <span class="text-md-primary font-medium">
          {contact.address}
        </span>
      </div>

    </div>

    <!-- Socials -->
    <div class="mt-8 grid sm:grid-cols-2 md:grid-cols-4 gap-3">

      <a href={contact.socials[0].url}
         class="bg-md-surface border border-md-outline-variant rounded-xl p-4 flex justify-between items-center hover:bg-md-surface-variant transition">
        <span class="text-sm text-md-on-surface-muted">Instagram</span>
        <span class="text-sm text-md-primary">@orionsoft</span>
      </a>

      <a href={contact.socials[1].url}
         class="bg-md-surface border border-md-outline-variant rounded-xl p-4 flex justify-between items-center hover:bg-md-surface-variant transition">
        <span class="text-sm text-md-on-surface-muted">LinkedIn</span>
        <span class="text-sm text-md-primary">OrionSoft</span>
      </a>

      <a href={contact.socials[2].url}
         class="bg-md-surface border border-md-outline-variant rounded-xl p-4 flex justify-between items-center hover:bg-md-surface-variant transition">
        <span class="text-sm text-md-on-surface-muted">GitHub</span>
        <span class="text-sm text-md-primary">Orionsoft</span>
      </a>

      <a href={contact.socials[3].url}
         class="bg-md-surface border border-md-outline-variant rounded-xl p-4 flex justify-between items-center hover:bg-md-surface-variant transition">
        <span class="text-sm text-md-on-surface-muted">WhatsApp</span>
        <span class="text-sm text-md-primary">Escribir</span>
      </a>

    </div>

  </div>
</section>