---
const contact = {
  email: "orionsoft@gmail.com",
  phone: "+1 (829) 793-1539",
  address: "La Altagracia, Punta Cana, República Dominicana",
  socials: [
    { name: "Instagram", handle: "@orionsoft", url: "https://instagram.com/orionsoft" },
    { name: "LinkedIn", handle: "OrionSoft", url: "https://linkedin.com/company/orionsoft" },
    { name: "GitHub", handle: "Orionsoft", url: "https://github.com/Theneillsaaco" },
    { name: "WhatsApp", handle: "+1 (829) 793-1539", url: "https://wa.me/18297931539" },
  ],
};
---
 <section id="contact" class="py-24 bg-gray-950">
  <div class="max-w-5xl mx-auto px-6">
 
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase text-emerald-400 bg-emerald-950 border border-emerald-800 px-4 py-1.5 rounded-full mb-4">
        Contacto
      </span>
      <h2 class="text-4xl font-bold text-white tracking-tight mb-3">
        Hablemos de tu proyecto
      </h2>
      <p class="text-gray-400 text-lg max-w-md mx-auto leading-relaxed">
        Estamos listos para escucharte. Escríbenos o encuéntranos en nuestras redes.
      </p>
    </div>
 
    <!-- Grid principal -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
 
      <!-- Email -->
      <a href={`mailto:${contact.email}`} class="group bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col gap-3 hover:border-emerald-800 transition-all duration-200 hover:-translate-y-1">
        <div class="w-10 h-10 rounded-xl bg-emerald-950 border border-emerald-800 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-1">Email</p>
          <p class="text-white font-medium group-hover:text-emerald-400 transition-colors">{contact.email}</p>
        </div>
      </a>
        <!-- Teléfono -->
      <a href={`tel:${contact.phone}`} class="group bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col gap-3 hover:border-emerald-800 transition-all duration-200 hover:-translate-y-1">
        <div class="w-10 h-10 rounded-xl bg-emerald-950 border border-emerald-800 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-1">Teléfono</p>
          <p class="text-white font-medium group-hover:text-emerald-400 transition-colors">{contact.phone}</p>
        </div>
      </a>
 
      <!-- Dirección -->
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col gap-3">
        <div class="w-10 h-10 rounded-xl bg-emerald-950 border border-emerald-800 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-1">Ubicación</p>
          <p class="text-white font-medium">{contact.address}</p>
        </div>
      </div>
 
    </div>
 
    <!-- Redes sociales -->
    <div class="mt-5 bg-gray-900 border border-gray-800 rounded-2xl p-8">
      <p class="text-xs text-gray-500 uppercase tracking-widest font-semibold mb-5">Síguenos en</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {contact.socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 bg-gray-800 border border-gray-700 rounded-xl px-4 py-3 hover:border-emerald-800 hover:bg-gray-800/80 transition-all duration-200"
          >
            <div class="flex flex-col">
              <span class="text-xs text-gray-500 font-semibold uppercase tracking-wider">{social.name}</span>
              <span class="text-sm text-gray-300 group-hover:text-emerald-400 transition-colors font-medium">{social.handle}</span>
            </div>
            <svg class="w-4 h-4 text-gray-600 group-hover:text-emerald-500 ml-auto transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        ))}
      </div>
    </div>
 
  </div>
</section>