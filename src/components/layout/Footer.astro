---
const year = new Date().getFullYear()

const links = {
  servicios: [
    { label: 'Desarrollo Web', href: '#' },
    { label: 'Apps Móviles', href: '#' },
    { label: 'UI/UX Design', href: '#' },
    { label: 'Consultoría', href: '#' },
  ],
  empresa: [
    { label: 'Nosotros', href: '#' },
    { label: 'Proyectos', href: '/projects' },
    { label: 'Blog', href: '#' },
    { label: 'Contacto', href: 'mailto:hola@nulvex.com' },
  ],
}
---

<footer class="border-t border-md-outline-variant bg-md-surface mt-30">
  <div class="max-w-300 mx-auto px-6 py-16 pb-8">

    <!-- Top -->
    <div class="grid md:grid-cols-[1fr_auto] gap-16 pb-12 border-b border-md-outline-variant">

      <!-- Brand -->
      <div class="max-w-90">
        <a href="/" class="flex items-center gap-2 text-md-primary no-underline mb-4">
          <img 
            src={`${import.meta.env.BASE_URL}/Logo.png`} 
            class="w-6 h-6 object-contain" 
            alt="Logo" 
          />
          <span class="font-bold text-[1.1rem] tracking-[-0.02em]">
            OrionSoft
          </span>
        </a>

        <p class="text-sm leading-7 text-md-on-surface-muted mb-5">
          Transformamos ideas en productos digitales de alto impacto. Apps, webs y experiencias que destacan.
        </p>

        <a href="mailto:orionsoft@gmail.com"
           class="text-sm text-md-primary border-b border-md-outline pb-0.5
                  hover:border-md-primary transition">
          orionsoft@gmail.com
        </a>
      </div>

      <!-- Links -->
      <div class="flex gap-12">
        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-md-on-surface-muted mb-1">
            Servicios
          </span>
          {links.servicios.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-md-on-surface-muted
                      hover:text-md-primary transition">
              {label}
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-md-on-surface-muted mb-1">
            Empresa
          </span>
          {links.empresa.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-md-on-surface-muted
                      hover:text-md-primary transition">
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 pt-7">
      <span class="text-[0.8125rem] text-md-on-surface-muted">
        © {year} OrionSoft. Todos los derechos reservados.
      </span>

      <div class="flex gap-2">
        <!-- GitHub -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-md-outline-variant
                  text-md-on-surface-muted
                  hover:text-md-primary
                  hover:border-md-outline
                  hover:bg-md-surface-variant
                  transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489..."/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-md-outline-variant
                  text-md-on-surface-muted
                  hover:text-md-primary
                  hover:border-md-outline
                  hover:bg-md-surface-variant
                  transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328..."/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>