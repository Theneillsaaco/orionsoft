---
const year = new Date().getFullYear()

const links = {
  servicios: [
    { label: 'Desarrollo Web', href: '#' },
    { label: 'Apps Móviles', href: '#' },
    { label: 'UI/UX Design', href: '#' },
    { label: 'Consultoría', href: '#' },
  ],
  empresa: [
    { label: 'Nosotros', href: '#' },
    { label: 'Proyectos', href: '/projects' },
    { label: 'Blog', href: '#' },
    { label: 'Contacto', href: 'mailto:hola@nulvex.com' },
  ],
}
---

<footer class="border-t border-[var(--color-md-outline-variant)] bg-[var(--color-md-surface)] mt-[120px]">
  <div class="max-w-[1200px] mx-auto px-6 py-16 pb-8">

    <!-- Top -->
    <div class="grid md:grid-cols-[1fr_auto] gap-16 pb-12 border-b border-[var(--color-md-outline-variant)]">

      <!-- Brand -->
      <div class="max-w-[360px]">
        <a href="/" class="flex items-center gap-2 text-[var(--color-md-primary)] no-underline mb-4">
          <svg class="w-6 h-6" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="6" fill="currentColor" opacity="0.12"/>
            <path d="M6 22L14 6L22 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 16H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="font-bold text-[1.1rem] tracking-[-0.02em] font-[var(--font-display)]">
            OrionSoft
          </span>
        </a>

        <p class="text-sm leading-7 text-[var(--color-md-on-surface-muted)] mb-5">
          Transformamos ideas en productos digitales de alto impacto. Apps, webs y experiencias que destacan.
        </p>

        <a href="mailto:hola@nulvex.com"
           class="text-sm text-[var(--color-md-primary)] border-b border-[var(--color-md-outline)] pb-[2px]
                  hover:border-[var(--color-md-primary)] transition">
          orionsoft@gmail.com
        </a>
      </div>

      <!-- Links -->
      <div class="flex gap-12">
        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--color-md-on-surface-muted)] mb-1">
            Servicios
          </span>
          {links.servicios.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-[var(--color-md-on-surface-muted)]
                      hover:text-[var(--color-md-primary)] transition">
              {label}
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-[var(--color-md-on-surface-muted)] mb-1">
            Empresa
          </span>
          {links.empresa.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-[var(--color-md-on-surface-muted)]
                      hover:text-[var(--color-md-primary)] transition">
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 pt-7">
      <span class="text-[0.8125rem] text-[var(--color-md-on-surface-muted)]">
        © {year} OrionSoft. Todos los derechos reservados.
      </span>

      <div class="flex gap-2">
        <!-- GitHub -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-[var(--color-md-outline-variant)]
                  text-[var(--color-md-on-surface-muted)]
                  hover:text-[var(--color-md-primary)]
                  hover:border-[var(--color-md-outline)]
                  hover:bg-[var(--color-md-surface-variant)]
                  transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489..."/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-[var(--color-md-outline-variant)]
                  text-[var(--color-md-on-surface-muted)]
                  hover:text-[var(--color-md-primary)]
                  hover:border-[var(--color-md-outline)]
                  hover:bg-[var(--color-md-surface-variant)]
                  transition">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328..."/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>