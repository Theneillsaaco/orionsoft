---
const year = new Date().getFullYear()

const links = {
  servicios: [
    { label: 'Desarrollo Web', href: '#' },
    { label: 'Apps Móviles', href: '#' },
    { label: 'UI/UX Design', href: '#' },
    { label: 'Consultoría', href: '#' },
  ],
  empresa: [
    { label: 'Nosotros', href: '#' },
    { label: 'Proyectos', href: '/projects' },
    { label: 'Blog', href: '#' },
    { label: 'Contacto', href: 'mailto:hola@nulvex.com' },
  ],
}
---

<footer class="border-t border-md-outline-variant bg-md-surface mt-30">
  <div class="max-w-300 mx-auto px-6 py-16 pb-8">

    <!-- Top -->
    <div class="grid md:grid-cols-[1fr_auto] gap-16 pb-12 border-b border-md-outline-variant">

      <!-- Brand -->
      <div class="max-w-90">
        <a href="/" class="flex items-center gap-2 text-md-primary no-underline mb-4">
          <img 
            src={`${import.meta.env.BASE_URL}/Logo.png`} 
            class="w-6 h-6 object-contain" 
            alt="Logo" 
          />
          <span class="font-bold text-[1.1rem] tracking-[-0.02em]">
            OrionSoft
          </span>
        </a>

        <p class="text-sm leading-7 text-md-on-surface-muted mb-5">
          Transformamos ideas en productos digitales de alto impacto. Apps, webs y experiencias que destacan.
        </p>

        <a href="mailto:orionsoft@gmail.com"
           class="text-sm text-md-primary border-b border-md-outline pb-0.5
                  hover:border-md-primary transition">
          orionsoft@gmail.com
        </a>
      </div>

      <!-- Links -->
      <div class="flex gap-12">
        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-md-on-surface-muted mb-1">
            Servicios
          </span>
          {links.servicios.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-md-on-surface-muted
                      hover:text-md-primary transition">
              {label}
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-3">
          <span class="text-xs font-medium tracking-[0.08em] uppercase text-md-on-surface-muted mb-1">
            Empresa
          </span>
          {links.empresa.map(({ label, href }) => (
            <a href={href}
               class="text-sm text-md-on-surface-muted
                      hover:text-md-primary transition">
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 pt-7">
      <span class="text-[0.8125rem] text-md-on-surface-muted">
        © {year} OrionSoft. Todos los derechos reservados.
      </span>

      <div class="flex gap-2">
        <!-- GitHub -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-md-outline-variant
                  text-md-on-surface-muted
                  hover:text-md-primary
                  hover:border-md-outline
                  hover:bg-md-surface-variant
                  transition">
          <svg fill="#ffffff" viewBox="0 0 24 24" role="img" xmlns="http://www.w3.org/2000/svg" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><title>GitHub icon</title><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></g></svg>
        </a>

        <!-- LinkedIn -->
        <a href="#"
           class="flex items-center justify-center w-9 h-9 rounded-full
                  border border-md-outline-variant
                  text-md-on-surface-muted
                  hover:text-md-primary
                  hover:border-md-outline
                  hover:bg-md-surface-variant
                  transition">
<svg fill="#ffffff" height="200px" width="200px" version="1.1" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 504.4 504.4" xml:space="preserve"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <g> <path d="M377.6,0.2H126.4C56.8,0.2,0,57,0,126.6v251.6c0,69.2,56.8,126,126.4,126H378c69.6,0,126.4-56.8,126.4-126.4V126.6 C504,57,447.2,0.2,377.6,0.2z M168,408.2H96v-208h72V408.2z M131.6,168.2c-20.4,0-36.8-16.4-36.8-36.8c0-20.4,16.4-36.8,36.8-36.8 c20.4,0,36.8,16.4,36.8,36.8C168,151.8,151.6,168.2,131.6,168.2z M408.4,408.2H408h-60V307.4c0-24.4-3.2-55.6-36.4-55.6 c-34,0-39.6,26.4-39.6,54v102.4h-60v-208h56v28h1.6c8.8-16,29.2-28.4,61.2-28.4c66,0,77.6,38,77.6,94.4V408.2z"></path> </g> </g> </g></svg>        </a>
      </div>
    </div>

  </div>
</footer>