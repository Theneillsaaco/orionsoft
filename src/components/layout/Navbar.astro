---
const links = [
  { href: '/orionsoft', label: 'Inicio' },
  { href: '/orionsoft/projects', label: 'Proyectos' },
]

const currentPath = Astro.url.pathname
---

<header class="fixed top-0 left-0 right-0 z-[100] px-4 py-3 animate-[fade-in_.6s_ease_both]">
  <div class="max-w-[1200px] mx-auto flex items-center gap-8 
              rounded-full border border-[var(--color-md-outline-variant)]
              bg-[color-mix(in_srgb,var(--color-md-surface)_80%,transparent)]
              backdrop-blur-xl backdrop-saturate-[180%]
              px-5 py-2.5">

    <!-- Logo -->
    <a href="/orionsoft" class="flex items-center gap-2 text-[var(--color-md-primary)] no-underline shrink-0">
      <svg class="w-7 h-7" viewBox="0 0 28 28" fill="none">
        <rect width="28" height="28" rx="6" fill="currentColor" opacity="0.12"/>
        <path d="M6 22L14 6L22 22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 16H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="font-bold text-[1.1rem] tracking-[-0.02em] font-[var(--font-display)]">
        OrionSoft
      </span>
    </a>

    <!-- Links -->
    <nav class="hidden md:flex items-center gap-1 flex-1">
      {links.map(({ href, label }) => {
        const active = currentPath === href
        return (
          <a
            href={href}
            class={`px-3.5 py-1.5 rounded-full text-sm transition-all duration-200
            ${active
              ? 'text-[var(--color-md-primary)] bg-[var(--color-md-surface-variant)]'
              : 'text-[var(--color-md-on-surface-muted)] hover:text-[var(--color-md-primary)] hover:bg-[var(--color-md-surface-variant)]'
            }`}
            aria-current={active ? 'page' : undefined}
          >
            {label}
          </a>
        )
      })}
    </nav>

    <!-- CTA -->
    <a href="mailto:orionsoft@gmail.com"
       class="hidden md:inline-flex shrink-0 px-5 py-2 text-xs rounded-full
              border border-[var(--color-md-outline)]
              text-[var(--color-md-primary)]
              hover:bg-[var(--color-md-surface-variant)]
              transition-all duration-200">
      Hablemos
    </a>

    <!-- Mobile toggle -->
    <button id="mobile-toggle"
            class="md:hidden ml-auto text-[var(--color-md-primary)] p-1">
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
        <path d="M3 6h14M3 10h14M3 14h14"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu"
       class="hidden flex-col gap-1 mt-2 px-5 py-4 rounded-2xl
              border border-[var(--color-md-outline-variant)]
              bg-[color-mix(in_srgb,var(--color-md-surface)_95%,transparent)]
              backdrop-blur-xl">

    {links.map(({ href, label }) => {
      const active = currentPath === href
      return (
        <a
          href={href}
          class={`px-3.5 py-2 rounded-md text-sm transition
          ${active
            ? 'text-[var(--color-md-primary)] bg-[var(--color-md-surface-variant)]'
            : 'text-[var(--color-md-on-surface-muted)] hover:text-[var(--color-md-primary)] hover:bg-[var(--color-md-surface-variant)]'
          }`}
        >
          {label}
        </a>
      )
    })}

    <a href="mailto:hola@nulvex.com"
       class="mt-2 inline-flex px-4 py-2 rounded-full text-sm
              bg-[var(--color-md-primary)] text-[var(--color-md-on-primary)]
              hover:opacity-90 transition">
      Hablemos
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle')
  const menu = document.getElementById('mobile-menu')

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
</script>